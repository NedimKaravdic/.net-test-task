@page "/profile"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@layout DashboardLayout

<PageTitle>@AppConstants.PortfolioTitle | @AppConstants.AppName</PageTitle>

<div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-white/5 pb-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">@AppConstants.PortfolioTitle</h1>
            <p class="text-slate-400 mt-2">@AppConstants.PortfolioSubTitle</p>
        </div>
        
        <div class="flex items-center gap-4 bg-slate-900/50 p-2 rounded-2xl border border-white/5">
            <span class="text-xs font-bold text-slate-500 uppercase tracking-widest px-2">@AppConstants.LabelDisplayIn</span>
            <select @bind="displayCurrency" class="bg-indigo-600 text-white text-sm font-bold rounded-xl px-4 py-2 outline-none cursor-pointer hover:bg-indigo-500 transition-colors">
                <option value="@AppConstants.DefaultCurrency">@AppConstants.DefaultCurrency</option>
                @foreach (var rate in rates.Select(r => r.CurrencyCode).Distinct())
                {
                    <option value="@rate">@rate</option>
                }
            </select>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Balance Card -->
        <div class="lg:col-span-2 bg-gradient-to-br from-indigo-600 to-indigo-900 rounded-[2.5rem] p-8 shadow-2xl shadow-indigo-500/20 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -mr-32 -mt-32 group-hover:scale-110 transition-transform duration-700"></div>
            
            <div class="relative z-10 flex flex-col h-full justify-between">
                <div>
                    <span class="text-indigo-100/60 text-sm font-bold uppercase tracking-[0.2em] mb-4 block">@AppConstants.LabelEstimatedBalance</span>
                    <div class="flex items-baseline gap-2">
                        <span class="text-5xl font-black text-white tracking-tight">@DisplayBalance.ToString("N2")</span>
                        <span class="text-xl font-bold text-indigo-200">@displayCurrency</span>
                    </div>
                </div>

                <div class="mt-12 flex gap-4">
                    <div class="flex-1 bg-white/10 backdrop-blur-md rounded-2xl p-4 border border-white/10">
                        <span class="text-indigo-200/60 text-[10px] font-bold uppercase tracking-widest block mb-1">Total Assets</span>
                        <span class="text-xl font-bold text-white">@balances.Count</span>
                    </div>
                    <div class="flex-1 bg-white/10 backdrop-blur-md rounded-2xl p-4 border border-white/10">
                        <span class="text-indigo-200/60 text-[10px] font-bold uppercase tracking-widest block mb-1">Default Base</span>
                        <span class="text-xl font-bold text-white">@AppConstants.DefaultCurrency</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Deposit Card -->
        <div class="bg-slate-900 border border-white/10 rounded-[2.5rem] p-8 relative overflow-hidden">
            <h3 class="text-xl font-bold text-white mb-6">@AppConstants.BtnDeposit</h3>
            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-widest ml-1">@AppConstants.PlaceholderAmount (USD)</label>
                    <input type="number" @bind="depositAmount" placeholder="0.00" class="w-full bg-slate-800 border border-white/10 rounded-2xl px-5 py-4 text-white text-xl font-bold focus:border-indigo-500 outline-none transition-all" />
                </div>
                <button @onclick="HandleDeposit" disabled="@isProcessing" class="w-full bg-white text-slate-900 hover:bg-indigo-50 disabled:bg-slate-700 disabled:text-slate-400 h-14 rounded-2xl font-bold text-lg shadow-xl transition-all active:scale-95 flex items-center justify-center gap-2">
                    @if (isProcessing)
                    {
                        <div class="w-5 h-5 border-2 border-slate-900/20 border-t-slate-900 rounded-full animate-spin"></div>
                    }
                    else
                    {
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4" /></svg>
                    }
                    @AppConstants.BtnDeposit
                </button>
            </div>
        </div>
    </div>

    <!-- Assets Table -->
    <div class="bg-slate-900 border border-white/10 rounded-[2.5rem] overflow-hidden">
        <div class="px-8 py-6 border-b border-white/5 flex items-center justify-between">
            <h2 class="text-xl font-bold text-white">@AppConstants.LabelYourAssets</h2>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] bg-white/[0.02]">
                        <th class="px-8 py-5">@AppConstants.HeaderAsset</th>
                        <th class="px-8 py-5">@AppConstants.HeaderBalance</th>
                        <th class="px-8 py-5">@AppConstants.HeaderPrice (USD)</th>
                        <th class="px-8 py-5 text-right">@AppConstants.HeaderValue (USD)</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @if (!balances.Any() && !isLoading)
                    {
                        <tr>
                            <td colspan="4" class="px-8 py-12 text-center text-slate-500 font-medium">@AppConstants.MsgEmptyWallet</td>
                        </tr>
                    }
                    @foreach (var balance in balances)
                    {
                        var rate = rates.FirstOrDefault(r => r.CurrencyCode == balance.CurrencyCode);
                        var valueInUsd = balance.CurrencyCode == AppConstants.DefaultCurrency ? balance.Amount : balance.Amount * (rate?.TransformedRate ?? 0);
                        
                        <tr class="hover:bg-white/[0.02] transition-colors group">
                            <td class="px-8 py-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-2xl bg-slate-800 border border-white/5 flex items-center justify-center font-bold text-indigo-400 group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                                        @balance.CurrencyCode.Substring(0, Math.Min(3, balance.CurrencyCode.Length))
                                    </div>
                                    <span class="font-bold text-white text-lg">@balance.CurrencyCode</span>
                                </div>
                            </td>
                            <td class="px-8 py-6">
                                <span class="text-slate-200 font-mono text-lg">@balance.Amount.ToString("N4")</span>
                            </td>
                            <td class="px-8 py-6">
                                <span class="text-slate-400 font-mono">@(balance.CurrencyCode == AppConstants.DefaultCurrency ? "1.0000" : rate?.TransformedRate.ToString("N4") ?? "---")</span>
                            </td>
                            <td class="px-8 py-6 text-right">
                                <span class="text-white font-bold text-lg">@valueInUsd.ToString("N2")</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
