@page "/trade"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@layout DashboardLayout

<PageTitle>@AppConstants.TradeTitle | @AppConstants.AppName</PageTitle>

<div class="max-w-md mx-auto mt-10 space-y-6">
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold tracking-tight">@AppConstants.TradeTitle</h1>
        <p class="text-slate-400 mt-2">@AppConstants.TradeSubTitle</p>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="bg-red-500/10 border border-red-500/20 text-red-500 rounded-xl p-4 mb-6 text-sm font-semibold flex items-center gap-2">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            @ErrorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-xl p-4 mb-6 text-sm font-semibold flex items-center gap-2">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            @SuccessMessage
        </div>
    }

    <div class="bg-slate-900 border border-white/10 rounded-3xl p-6 shadow-2xl space-y-4">
        <div class="bg-slate-800/50 rounded-2xl p-4 border border-white/5 transition-colors focus-within:border-indigo-500/50">
            <div class="flex justify-between text-xs text-slate-400 font-bold mb-2">
                <span>@AppConstants.LabelSell</span>
                <span>@AppConstants.LabelBalance: <span class="text-white">@FromBalance.ToString("N4") @FromCurrency</span></span>
            </div>
            <div class="flex items-center gap-4">
                <input type="number" @bind="AmountToSell" @bind:event="oninput" min="0" step="any" placeholder="0.00" class="w-full bg-transparent text-3xl font-bold text-white outline-none" />
                <select @bind="FromCurrency" class="w-32 bg-slate-700 text-white font-bold rounded-xl px-4 py-2 outline-none cursor-pointer hover:bg-slate-600 transition-colors">
                    @if (OwnedCurrencies.Any())
                    {
                        @foreach (var curr in OwnedCurrencies)
                        {
                            <option value="@curr">@curr</option>
                        }
                    }
                    else
                    {
                        <option value="">Empty Wallet</option>
                    }
                </select>
            </div>
        </div>

        <div class="flex justify-center -my-6 relative z-10">
            <div class="w-10 h-10 bg-indigo-600 rounded-xl border-4 border-slate-900 flex items-center justify-center text-white shadow-lg">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg>
            </div>
        </div>

        <div class="bg-slate-800/50 rounded-2xl p-4 border border-white/5 transition-colors focus-within:border-indigo-500/50">
            <div class="flex justify-between text-xs text-slate-400 font-bold mb-2">
                <span>@AppConstants.LabelBuy</span>
                <span>@AppConstants.LabelBalance: <span class="text-white">@ToBalance.ToString("N4") @ToCurrency</span></span>
            </div>
            <div class="flex items-center gap-4">
                @if (IsCalculating)
                {
                    <div class="w-full h-10 bg-white/5 animate-pulse rounded-lg"></div>
                }
                else
                {
                    <input type="text" readonly value="@EstimatedReceive.ToString("0.0000")" class="w-full bg-transparent text-3xl font-bold text-emerald-400 outline-none cursor-not-allowed" />
                }
                <select @bind="ToCurrency" class="w-32 bg-slate-700 text-white font-bold rounded-xl px-4 py-2 outline-none cursor-pointer hover:bg-slate-600 transition-colors">
                    @if (!rates.Any(r => r.CurrencyCode == AppConstants.DefaultCurrency)) { <option value="@AppConstants.DefaultCurrency">@AppConstants.DefaultCurrency</option> }
                    @foreach (var rate in rates.Select(r => r.CurrencyCode).Distinct())
                    {
                        <option value="@rate">@rate</option>
                    }
                </select>
            </div>
        </div>

        <div class="px-2 pt-2 space-y-2 text-sm">
            <div class="flex justify-between text-slate-400">
                <span>@AppConstants.LabelRate</span>
                <span class="text-white font-mono">1 @FromCurrency = @(CurrentRate > 0 ? CurrentRate.ToString("N4") : "---") @ToCurrency</span>
            </div>
        </div>

        <button @onclick="ExecuteTrade" disabled="@(IsTrading || IsCalculating)" class="w-full mt-6 h-14 bg-indigo-600 hover:bg-indigo-500 disabled:bg-indigo-600/50 text-white font-bold text-lg rounded-xl shadow-lg shadow-indigo-600/20 transition-all active:scale-95 flex justify-center items-center gap-2">
            @if (IsTrading)
            {
                <div class="w-5 h-5 border-2 border-white/20 border-t-white rounded-full animate-spin"></div>
                <span>@AppConstants.BtnExecuting</span>
            }
            else
            {
                <span>@AppConstants.BtnConfirmTrade</span>
            }
        </button>
    </div>
</div>
