@page "/"
@layout DashboardLayout

<PageTitle>@AppConstants.DashboardTitle | @AppConstants.AppName</PageTitle>

<div class="space-y-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">@AppConstants.DashboardTitle (@(latestRates.FirstOrDefault()?.BaseCurrency ?? "---"))</h1>
            <p class="text-slate-400 mt-1">@AppConstants.LabelProviderDate: <span class="text-indigo-400 font-mono">@(latestRates.FirstOrDefault()?.ProviderDate ?? "---")</span></p>
        </div>
        
        <div class="flex items-center gap-3">
            <button @onclick="SyncMarkets" disabled="@isSyncing" class="h-11 px-6 rounded-xl bg-indigo-600 hover:bg-indigo-500 disabled:bg-indigo-600/50 text-white font-semibold transition-all shadow-lg shadow-indigo-600/20 flex items-center gap-2 group">
                @if (isSyncing)
                {
                    <div class="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin"></div>
                    <span>@AppConstants.BtnSyncing</span>
                }
                else
                {
                    <svg class="w-4 h-4 group-hover:rotate-180 transition-transform duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                    <span>@AppConstants.BtnSyncMarkets</span>
                }
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="p-5 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md">
            <div class="flex items-center justify-between text-slate-400 mb-3">
                <span class="text-xs font-semibold uppercase tracking-widest">@AppConstants.LabelActiveAssets</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 7v10c0 1.1.9 2 2 2h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2z"/></svg>
            </div>
            <div class="flex items-end gap-2">
                <span class="text-3xl font-bold text-white">@latestRates.Count</span>
                <span class="text-emerald-400 text-xs font-medium mb-1.5">@AppConstants.LabelTracked</span>
            </div>
        </div>


        <div class="p-5 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md">
            <div class="flex items-center justify-between text-slate-400 mb-3">
                <h3 class="font-bold text-indigo-400">@AppConstants.LabelSystemMargin</h3>
            </div>
            <div class="flex items-end gap-2">
                <span class="text-3xl font-bold text-indigo-400">@AppConstants.ServiceFeeDisplay</span>
                <span class="text-slate-500 text-xs mb-1.5">@AppConstants.LabelApplied</span>
            </div>
        </div>

        <div class="p-5 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md relative overflow-hidden group">
            <div class="absolute inset-0 bg-indigo-500/5 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
            <div class="relative items-center gap-2 mb-4">
                <div class="w-8 h-8 rounded-lg bg-indigo-500/20 flex items-center justify-center mb-2">
                    <svg class="w-4 h-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                </div>
                <h3 class="font-bold text-white">@AppConstants.LabelMarketLeaders</h3>
            </div>
            <div class="relative flex items-end gap-2">
                <span class="text-3xl font-bold">@((latestRates.MaxBy(r => r.TransformedRate)?.CurrencyCode ?? "---"))</span>
                <span class="text-slate-500 text-xs mb-1.5">@AppConstants.LabelHighest</span>
            </div>
        </div>
    </div>


    <div class="bg-gradient-to-r from-indigo-900/40 to-slate-900 border border-indigo-500/20 rounded-2xl p-6 backdrop-blur-md">
        <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
            @AppConstants.LabelInstantConverter
        </h2>
        <div class="flex flex-col md:flex-row items-center gap-4">
            <div class="flex-1 w-full bg-black/20 rounded-xl p-2 border border-white/10 flex items-center">
                <input type="number" @bind="converterAmount" @bind:event="oninput" class="flex-1 bg-transparent text-xl font-bold px-4 py-2 outline-none text-white" placeholder="0.00" />
                <div class="h-8 w-px bg-white/10 mx-2"></div>
                <select @bind="selectedCurrency" class="bg-transparent font-bold px-4 py-2 outline-none cursor-pointer">
                    @foreach (var rate in latestRates)
                    {
                        <option value="@rate.CurrencyCode">@rate.CurrencyCode</option>
                    }
                </select>
            </div>
            <div class="text-indigo-400">
                <svg class="w-6 h-6 md:rotate-0 rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </div>
            <div class="flex-1 w-full bg-white/5 rounded-xl p-4 border border-white/10 text-center">
                <span class="text-slate-400 text-sm font-bold uppercase tracking-widest block mb-1">@AppConstants.LabelResult</span>
                <span class="text-2xl font-bold text-emerald-400">@ConvertedValue.ToString("N2") @AppConstants.DefaultCurrency</span>
            </div>
        </div>
    </div>

    <!-- Market Trend Chart -->
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm">
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center">
                    <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
                </div>
                <div>
                    <h2 class="text-lg font-bold">@selectedCurrency Market Trend</h2>
                    <p class="text-xs text-slate-500 font-bold uppercase tracking-widest">24-hour analytical projection</p>
                </div>
            </div>
            <div class="text-right flex flex-col items-end gap-2">
                <div class="flex items-center bg-slate-800 rounded-lg p-1 border border-white/5">
                    <button @onclick='() => ChangeRange("1D")' class="px-3 py-1 rounded-md text-[10px] font-bold transition-all @(selectedRange == "1D" ? "bg-indigo-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">1D</button>
                    <button @onclick='() => ChangeRange("1W")' class="px-3 py-1 rounded-md text-[10px] font-bold transition-all @(selectedRange == "1W" ? "bg-indigo-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">1W</button>
                    <button @onclick='() => ChangeRange("1M")' class="px-3 py-1 rounded-md text-[10px] font-bold transition-all @(selectedRange == "1M" ? "bg-indigo-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300")">1M</button>
                </div>
                <div>
                    <span class="text-2xl font-black text-white">@(latestRates.FirstOrDefault(r => r.CurrencyCode == selectedCurrency)?.TransformedRate.ToString("N4") ?? "---")</span>
                    <span class="block text-[10px] text-emerald-400 font-bold tracking-tighter uppercase">+0.12% TODAY</span>
                </div>
            </div>
        </div>
        <div class="h-[300px] w-full relative">
            <canvas id="marketChartCanvas"></canvas>
        </div>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden backdrop-blur-sm">
        <div class="px-6 py-4 border-b border-white/5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <h2 class="text-lg font-bold">@AppConstants.LabelAllMarkets</h2>
            <div class="relative w-full sm:w-64">
                <input type="text" @bind="SearchTerm" @bind:event="oninput" placeholder="@AppConstants.PlaceholderSearch" class="w-full bg-slate-900 border border-white/10 rounded-lg pl-9 pr-4 py-2 text-sm text-white focus:outline-none focus:border-indigo-500 transition-colors" />
                <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left relative">
                <thead class="sticky top-0 z-10 bg-slate-900 border-b border-white/5">
                    <tr class="text-xs font-bold text-slate-500 uppercase tracking-widest bg-black/20 backdrop-blur-md">
                        <th class="px-6 py-4">@AppConstants.HeaderAsset</th>
                        <th class="px-6 py-4">@AppConstants.HeaderSymbol</th>
                        <th class="px-6 py-4">@AppConstants.HeaderQuote</th>
                        <th class="px-6 py-4">@AppConstants.HeaderPrice</th>
                        <th class="px-6 py-4">@AppConstants.HeaderVolatility</th>
                        <th class="px-6 py-4 text-right">@AppConstants.HeaderUpdated</th>
                        <th class="px-6 py-4 text-center">@AppConstants.HeaderAction</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var rate in FilteredRates)
                    {
                        <tr class="hover:bg-white/[0.03] transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center font-bold text-indigo-400 border border-white/5 group-hover:border-indigo-500/50 transition-colors shadow-inner">
                                        @rate.CurrencyCode.Substring(0, Math.Min(3, rate.CurrencyCode.Length))
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-white">@rate.CurrencyCode</span>
                                        <span class="text-[10px] text-slate-500 font-bold uppercase tracking-tight">@AppConstants.LabelMarketAsset</span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-[10px] text-slate-400 font-bold">@rate.BaseCurrency</span>
                            </td>
                            <td class="px-6 py-4 font-mono text-sm text-slate-400">
                                @rate.RawRate.ToString("0.00000")
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="font-bold text-white text-lg leading-none">@rate.TransformedRate.ToString("0.0000")</span>
                                    <span class="text-[10px] text-indigo-400 opacity-60 font-semibold uppercase tracking-tighter">+@AppConstants.ServiceFeeDisplay SERVICE FEE</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2 py-1 rounded-lg text-[10px] font-bold @(rate.VolatilityTag == "High" ? "bg-red-500/10 text-red-400 border border-red-500/20" : "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20")">
                                    @rate.VolatilityTag
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right font-mono text-sm text-slate-500">
                                @rate.ProviderDate
                            </td>
                            <td class="px-6 py-4 text-center">
                                <a href="/trade" class="h-9 px-4 rounded-lg bg-white/5 hover:bg-white/10 text-white text-sm font-semibold transition-colors flex items-center justify-center gap-2">
                                    @AppConstants.BtnTrade
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
