@page "/not-found"
@layout DashboardLayout

<PageTitle>Not Found | ExchangePro</PageTitle>

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center relative z-10">
    <div class="absolute w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl -z-10"></div>
    <h1 class="text-9xl font-bold tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-indigo-400 to-slate-600 mb-4">404</h1>
    <h2 class="text-2xl font-bold tracking-tight text-white mb-2">Market Data Not Found</h2>
    <p class="text-slate-400 mb-8 max-w-md">Sorry, but the page or asset you are looking for has either been delisted or does not exist.</p>
    <a href="/" class="bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl px-8 py-3 shadow-lg shadow-indigo-600/20 transition-all active:scale-95">
        Return to Dashboard
    </a>
</div>