@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="min-h-screen bg-slate-950 text-slate-200 selection:bg-indigo-500/30 font-sans">
    <nav class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/80 backdrop-blur-xl">
        <div class="max-w-[1400px] mx-auto px-4 h-16 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <div class="flex items-center gap-2">
                    <span
                        class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white to-slate-400 tracking-tight">
                        @AppConstants.AppName
                    </span>
                </div>

                <div class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-400">
                    <a href="/" class="hover:text-white transition-colors">@AppConstants.DashboardTitle</a>
                    <AuthorizeView>
                        <Authorized>
                            <a href="/trade" class="hover:text-white transition-colors">@AppConstants.BtnTrade</a>
                            <a href="/profile" class="hover:text-white transition-colors">@AppConstants.PortfolioTitle</a>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <AuthorizeView>
                    <Authorized>
                        <button @onclick="ShowLogout" class="hover:text-white transition-colors text-slate-400 text-sm font-medium">@AppConstants.BtnLogout</button>
                    </Authorized>
                    <NotAuthorized>
                        <div class="flex items-center gap-4">
                            <a href="/login" class="hover:text-white transition-colors text-sm font-medium">@AppConstants.BtnLogin</a>
                            <a href="/register" class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors text-sm font-medium">@AppConstants.BtnRegister</a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>

            </div>
        </div>
    </nav>

    @if (showLogoutModal)
    {
        <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-950/60 backdrop-blur-md animate-in fade-in duration-200">
            <div class="w-full max-w-sm bg-slate-900 border border-white/10 rounded-3xl p-8 shadow-2xl scale-in-center animate-in zoom-in-95 duration-200">
                <div class="w-16 h-16 bg-red-500/10 rounded-2xl flex items-center justify-center mb-6 border border-red-500/20 mx-auto">
                    <svg class="w-8 h-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                </div>
                
                <h2 class="text-2xl font-bold text-white text-center mb-2">Logout</h2>
                <p class="text-slate-400 text-center mb-8">Are you sure you want to exit? You will need to login again to access your wallet.</p>
                
                <div class="grid grid-cols-2 gap-4">
                    <button @onclick="HideLogout" class="h-12 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors font-bold text-slate-300">
                        @AppConstants.BtnCancel
                    </button>
                    
                    <form action="/api/logout" method="post">
                        <AntiforgeryToken />
                        <button type="submit" class="w-full h-12 rounded-xl bg-red-600 hover:bg-red-500 transition-colors font-bold text-white shadow-lg shadow-red-600/20">
                            Confirm
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }

    <main class="max-w-[1400px] mx-auto px-4 py-8">
        @Body
    </main>

    <footer
        class="max-w-[1400px] mx-auto px-4 py-12 border-t border-white/5 opacity-50 text-xs text-center tracking-wide">
        &copy; 2026 @AppConstants.AppName.
    </footer>
</div>

@code {
    private bool showLogoutModal = false;

    private void ShowLogout() => showLogoutModal = true;
    private void HideLogout() => showLogoutModal = false;
}
